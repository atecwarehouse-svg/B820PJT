# Supabase 프로젝트 설정 (Settings > API 에서 복사)
# 실제 값은 .env.local 에 넣으세요 (.env.local 은 git에 커밋되지 않음).
# ⚠️ 이 파일(.env.example)은 git에 커밋되므로 실제 키를 넣지 마세요.

# 클라이언트(브라우저)에 노출되는 공개 키
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# 서버 전용 키 — 절대 클라이언트/저장소에 노출 금지 (API route, 스크립트에서만 사용)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Google Drive (사진 파일 저장소) ──────────────────────────
# Google Cloud Console > 사용자 인증 정보 > OAuth 클라이언트 ID("데스크톱 앱")에서 발급.
# OAuth 동의 화면은 "프로덕션"으로 게시해야 리프레시 토큰이 만료되지 않음
# (drive.file 스코프만 쓰면 구글 검증 절차 불필요).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...            # 서버 전용, 비공개
# 아래 두 값은 `npm run gdrive:setup` 실행 결과로 채웁니다.
GOOGLE_REFRESH_TOKEN=...            # 서버 전용, 비공개
GDRIVE_FOLDER_ID=...               # 사진을 저장할 드라이브 폴더 ID

# ── Gemini (사진 회전 자동 검사 + 기준사진 비교) ─────────────
# Google AI Studio(https://aistudio.google.com) > "Get API key" 에서 발급.
# 미설정 시 회전 검사·기준사진 비교는 자동으로 건너뜀(업로드 정상 동작).
GEMINI_API_KEY=...                 # 서버 전용, 비공개

# ── 관리자 페이지 비밀번호 ───────────────────────────────────
# 미설정 시 코드 기본값(atec1004!!) 사용. 변경하려면 여기에 설정.
# 설치일정 변경 업로드·금일 완료 리포트 발송에도 이 비밀번호를 사용.
ADMIN_PASSWORD=...                 # 서버 전용, 비공개

# ── 진행현황 엑셀 다운로드 비밀번호 ──────────────────────────
# 미설정 시 코드 기본값(wktks2020!!) 사용. 변경하려면 여기에 설정.
PROGRESS_DOWNLOAD_PASSWORD=...     # 서버 전용, 비공개

# ── Teams 설치완료 카드 (진행현황과 다른 채팅방) ──────────────
# 차량 1대 '저장'(완료) 시 "운수사 차량번호 설치완료" 카드를 보낼 워크플로 웹후크.
# 미설정 시 발송 생략. (TEAMS_WEBHOOK_URL 과는 다른 채팅방의 웹후크)
TEAMS_COMPLETE_WEBHOOK_URL=...     # 서버 전용, 비공개

# ── Teams 관리자 호출 카드 (위 두 웹후크와 또 다른 채팅방) ────
# 홈 화면 "관리자 호출" 버튼을 누르면 이 웹후크로 🚨 카드를 보냄.
# Power Automate "웹후크 요청 수신" 워크플로로 새로 발급 (기존 웹후크와 같은 방식).
# 미설정 시 호출이 실패하며 화면에 에러 메시지가 표시됨.
TEAMS_ADMIN_CALL_WEBHOOK_URL=...   # 서버 전용, 비공개
