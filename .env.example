# Supabase 프로젝트 설정 (Settings > API 에서 복사)
# 실제 값은 .env.local 에 넣으세요 (.env.local 은 git에 커밋되지 않음).
# ⚠️ 이 파일(.env.example)은 git에 커밋되므로 실제 키를 넣지 마세요.

# 클라이언트(브라우저)에 노출되는 공개 키
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# 서버 전용 키 — 절대 클라이언트/저장소에 노출 금지 (API route, 스크립트에서만 사용)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
